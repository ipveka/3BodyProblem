# Keep the deployment (and the serverless function bundle) lean: only the
# frontend, the API entry point, and the backend/core packages are needed.
tests/
scripts/
visualization/
docs/
.github/
Dockerfile
docker-compose.yml
.dockerignore
render.yaml
# Anchor to the repo root with a leading slash so these do NOT match the
# function's own api/requirements.txt (a bare "requirements.txt" pattern would
# match at any depth and break Python function detection on Vercel).
/requirements.txt
/requirements-api.txt
frontend/node_modules/
frontend/dist/
